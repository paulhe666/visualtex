# JavaScript
node_modules/
apps/*/node_modules/
apps/*/dist/
apps/*/dist-office/
apps/*/dist-office-macos/
apps/*/dist-office-windows-ole/
apps/*/dist-readme/
apps/*/dist-ocr/
.npm-cache/
.vite/

# Rust / Tauri
apps/*/src-tauri/target/
apps/*/src-tauri/gen/
apps/*/src-tauri/binaries/*.exe
apps/*/src-tauri/resources/windows-office/*.msi
apps/*/src-tauri/resources/windows-office/*.sha256.json

# Windows native builds
apps/windows/src-windows/**/bin/
apps/windows/src-windows/**/obj/
apps/windows/src-windows/**/TestResults/
apps/windows/src-windows/artifacts/
apps/windows/WINDOWS-BUILD-OUTPUT/

# OCR runtimes and caches
apps/*/.cache/
apps/*/ocr/.venv/
apps/*/ocr/output/
__pycache__/
*.py[cod]

# Generated Office resources
apps/*/office/macos/icons/
apps/*/office/macos/licenses/
apps/*/office/macos/vendor/
apps/*/office/macos/manifests/VisualTeX.*.xml
apps/*/office/windows/ole/icons/
apps/*/office/windows/ole/licenses/
apps/*/office/windows/ole/vendor/
apps/*/office/windows/ole/manifests/VisualTeX.*.xml

# Local files
.DS_Store
*.log
.tmp-*
.agents/
.codex/
