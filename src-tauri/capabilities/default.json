{
  "$schema": "../gen/schemas/desktop-schema.json",
  "identifier": "default",
  "description": "Default capability for VisualTeX",
  "windows": ["main"],
  "permissions": [
    "core:default",
    "dialog:allow-open",
    {
      "identifier": "opener:allow-open-url",
      "allow": [
        { "url": "https://github.com/paulhe666/visualtex/releases" },
        { "url": "https://github.com/paulhe666/visualtex/releases/*" }
      ]
    }
  ]
}
