{
  "name": "visualtex-windows",
  "private": true,
  "version": "1.2.1",
  "license": "MIT",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "npm run build:desktop",
    "build:desktop": "tsc --noEmit && vite build",
    "prepare:office:windows-ole": "node scripts/prepare_office_platform_resources.mjs windows-ole",
    "prepare:office": "npm run prepare:office:windows-ole",
    "build:office:windows-ole": "npm run prepare:office:windows-ole && tsc -p tsconfig.office.json --noEmit && vite build -c vite.office.windows-ole.config.ts && node scripts/finalize_office_platform_build.mjs windows-ole",
    "build:office": "npm run build:office:windows-ole",
    "prepare:ocr-offline": "python3 scripts/prepare_offline_ocr_runtime.py",
    "prepare:ocr-model-packs": "python3 scripts/prepare_offline_ocr_runtime.py --with-optional-model-packs",
    "build:all": "npm run build:desktop && npm run build:office:windows-ole",
    "build:bundle": "node scripts/build_platform_bundle.mjs",
    "preview": "vite preview",
    "tauri": "tauri",
    "tauri:dev": "tauri dev",
    "tauri:build": "node scripts/tauri_build.mjs",
    "test:editor:run": "node scripts/editor_regression_smoke.mjs",
    "test:editor": "npm run build && npm run test:editor:run",
    "test:editor-history:run": "node scripts/editor_history_regression.mjs",
    "test:editor-history": "npm run build && npm run test:editor-history:run",
    "test:history": "node scripts/history_manager_smoke.mjs",
    "test:latex-format": "node --experimental-strip-types scripts/latex_format_smoke.mjs",
    "test:update-notes": "node --experimental-strip-types scripts/update_notes_smoke.mjs",
    "test:svg-export": "node --experimental-strip-types scripts/svg_export_smoke.mjs",
    "test:office-metadata": "node --experimental-strip-types scripts/office_metadata_smoke.mjs",
    "test:word-adapter": "tsx scripts/word_adapter_smoke.mjs",
    "test:word-baseline": "tsx scripts/word_baseline_regression.mjs",
    "test:powerpoint-adapter": "node scripts/run_powerpoint_adapter_smoke.mjs",
    "test:office-bridge": "tsx scripts/office_bridge_lifecycle_smoke.mjs",
    "test:office-ocr": "tsx scripts/office_ocr_transport_smoke.mjs",
    "verify:ocr-offline": "python3 scripts/verify_offline_ocr_bundle.py",
    "verify:ocr-offline:full": "python3 scripts/verify_offline_ocr_bundle.py --full",
    "verify:ocr-model-packs": "python3 scripts/verify_offline_ocr_bundle.py --model-packs dist-ocr/model-packs/macos-arm64",
    "verify:office-manifest": "npm run prepare:office:windows-ole && node scripts/verify_office_manifests.mjs",
    "test:platform-onboarding": "tsx scripts/platform_onboarding_smoke.mjs",
    "test:windows-office-architecture": "node scripts/windows_office_architecture_smoke.mjs",
    "verify:windows-release": "powershell.exe -NoProfile -ExecutionPolicy Bypass -File scripts/verify_windows_release_artifacts.ps1"
  },
  "dependencies": {
    "@codemirror/commands": "^6.8.1",
    "@codemirror/state": "^6.5.2",
    "@codemirror/view": "^6.36.5",
    "@tauri-apps/api": "^2.5.0",
    "@tauri-apps/plugin-dialog": "2.7.1",
    "@tauri-apps/plugin-opener": "^2.5.4",
    "codemirror-lang-latex": "^0.4.1",
    "fflate": "^0.8.2",
    "lucide-react": "^0.468.0",
    "mathjax-full": "^3.2.2",
    "mathlive": "^0.109.0",
    "react": "^19.1.0",
    "react-dom": "^19.1.0",
    "zustand": "^5.0.3"
  },
  "devDependencies": {
    "@microsoft/office-js": "^1.1.110",
    "@tauri-apps/cli": "^2.5.0",
    "@types/office-js": "^1.0.599",
    "@types/react": "^19.1.0",
    "@types/react-dom": "^19.1.0",
    "@vitejs/plugin-react": "^4.4.1",
    "tsx": "^4.20.6",
    "typescript": "~5.8.3",
    "vite": "^6.3.5"
  }
}
