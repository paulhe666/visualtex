{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "VisualTeX",
  "version": "1.2.0",
  "identifier": "com.visualtex.studio",
  "build": {
    "beforeDevCommand": "node scripts/build_office_for_platform.mjs && npm run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "npm run build:bundle",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "VisualTeX",
        "width": 1240,
        "height": 820,
        "minWidth": 640,
        "minHeight": 480,
        "resizable": true,
        "center": true,
        "visible": false
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "category": "Productivity",
    "shortDescription": "专业的 LaTeX 可视化公式编辑器",
    "longDescription": "使用可视化结构、智能命令候选、PaddleOCR 公式识别和实时源码共同编辑 LaTeX 数学公式。",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "resources": {
      "ocr/worker.py": "ocr/worker.py"
    },
    "macOS": {
      "signingIdentity": "-"
    },
    "windows": {
      "nsis": {
        "installerHooks": "./windows/hooks.nsh"
      }
    }
  }
}
