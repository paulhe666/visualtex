<?xml version="1.0" encoding="UTF-8" standalone="yes"?>
<OfficeApp xmlns="http://schemas.microsoft.com/office/appforoffice/1.1" xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xmlns:bt="http://schemas.microsoft.com/office/officeappbasictypes/1.0" xmlns:ov="http://schemas.microsoft.com/office/taskpaneappversionoverrides" xsi:type="TaskPaneApp">
  <Id>{{POWERPOINT_ADDIN_ID}}</Id>
  <Version>{{MANIFEST_VERSION}}</Version>
  <ProviderName>VisualTeX</ProviderName>
  <DefaultLocale>en-US</DefaultLocale>
  <DisplayName DefaultValue="VisualTeX Windows OLE for PowerPoint">
    <Override Locale="zh-CN" Value="VisualTeX Windows OLE（PowerPoint）" />
  </DisplayName>
  <Description DefaultValue="VisualTeX Windows PowerPoint OLE formula integration.">
    <Override Locale="zh-CN" Value="VisualTeX Windows PowerPoint OLE 公式集成。" />
  </Description>
  <IconUrl DefaultValue="{{COMPANION_ORIGIN}}/icons/icon-32.png" />
  <HighResolutionIconUrl DefaultValue="{{COMPANION_ORIGIN}}/icons/icon-80.png" />
  <SupportUrl DefaultValue="{{COMPANION_ORIGIN}}/bridge/index.html" />
  <AppDomains><AppDomain>{{COMPANION_ORIGIN}}</AppDomain></AppDomains>
  <Hosts><Host Name="Presentation" /></Hosts>
  <DefaultSettings><SourceLocation DefaultValue="{{COMPANION_ORIGIN}}/bridge/index.html" /></DefaultSettings>
  <Permissions>ReadWriteDocument</Permissions>
  <VersionOverrides xmlns="http://schemas.microsoft.com/office/taskpaneappversionoverrides" xsi:type="VersionOverridesV1_0">
    <Requirements><bt:Sets DefaultMinVersion="1.1"><bt:Set Name="AddinCommands" MinVersion="1.1" /></bt:Sets></Requirements>
    <Hosts><Host xsi:type="Presentation"><DesktopFormFactor>
      <FunctionFile resid="Commands.Url" />
      <ExtensionPoint xsi:type="PrimaryCommandSurface"><CustomTab id="VisualTeX.WindowsOle.Tab"><Group id="VisualTeX.Ole.Formulas">
        <Label resid="FormulaGroup.Label" />
        <Icon><bt:Image size="16" resid="Icon.16" /><bt:Image size="32" resid="Icon.32" /><bt:Image size="80" resid="Icon.80" /></Icon>
        <Control xsi:type="Button" id="VisualTeX.WindowsOle.NewFormula"><Label resid="New.Label" /><Supertip><Title resid="New.Label" /><Description resid="New.Desc" /></Supertip><Icon><bt:Image size="16" resid="Icon.16" /><bt:Image size="32" resid="Icon.32" /><bt:Image size="80" resid="Icon.80" /></Icon><Action xsi:type="ExecuteFunction"><FunctionName>newFormula</FunctionName></Action></Control>
        <Control xsi:type="Button" id="VisualTeX.WindowsOle.EditFormula"><Label resid="Edit.Label" /><Supertip><Title resid="Edit.Label" /><Description resid="Edit.Desc" /></Supertip><Icon><bt:Image size="16" resid="Icon.16" /><bt:Image size="32" resid="Icon.32" /><bt:Image size="80" resid="Icon.80" /></Icon><Action xsi:type="ExecuteFunction"><FunctionName>editFormula</FunctionName></Action></Control>
        <Control xsi:type="Button" id="VisualTeX.WindowsOle.OpenDesktop"><Label resid="Open.Label" /><Supertip><Title resid="Open.Label" /><Description resid="Open.Desc" /></Supertip><Icon><bt:Image size="16" resid="Icon.16" /><bt:Image size="32" resid="Icon.32" /><bt:Image size="80" resid="Icon.80" /></Icon><Action xsi:type="ExecuteFunction"><FunctionName>openDesktop</FunctionName></Action></Control>
      </Group><Label resid="Tab.Label" /></CustomTab></ExtensionPoint>
    </DesktopFormFactor></Host></Hosts>
    <Resources>
      <bt:Images><bt:Image id="Icon.16" DefaultValue="{{COMPANION_ORIGIN}}/icons/icon-16.png" /><bt:Image id="Icon.32" DefaultValue="{{COMPANION_ORIGIN}}/icons/icon-32.png" /><bt:Image id="Icon.80" DefaultValue="{{COMPANION_ORIGIN}}/icons/icon-80.png" /></bt:Images>
      <bt:Urls><bt:Url id="Commands.Url" DefaultValue="{{COMPANION_ORIGIN}}/bridge/index.html" /></bt:Urls>
      <bt:ShortStrings>
        <bt:String id="Tab.Label" DefaultValue="VisualTeX"><bt:Override Locale="zh-CN" Value="VisualTeX" /></bt:String>
        <bt:String id="FormulaGroup.Label" DefaultValue="Formulas"><bt:Override Locale="zh-CN" Value="公式" /></bt:String>
        <bt:String id="New.Label" DefaultValue="New Formula"><bt:Override Locale="zh-CN" Value="新建公式" /></bt:String>
        <bt:String id="Edit.Label" DefaultValue="Edit Selected Formula"><bt:Override Locale="zh-CN" Value="编辑所选公式" /></bt:String>
        <bt:String id="Open.Label" DefaultValue="Open VisualTeX"><bt:Override Locale="zh-CN" Value="打开 VisualTeX" /></bt:String>
      </bt:ShortStrings>
      <bt:LongStrings>
        <bt:String id="New.Desc" DefaultValue="Insert a VisualTeX formula on the current slide through the Windows OLE Bridge."><bt:Override Locale="zh-CN" Value="通过 Windows OLE Bridge 在当前幻灯片中插入 VisualTeX 公式。" /></bt:String>
        <bt:String id="Edit.Desc" DefaultValue="Edit the selected VisualTeX formula."><bt:Override Locale="zh-CN" Value="编辑当前选中的 VisualTeX 公式。" /></bt:String>
        <bt:String id="Open.Desc" DefaultValue="Open the VisualTeX desktop application."><bt:Override Locale="zh-CN" Value="打开 VisualTeX 桌面应用。" /></bt:String>
      </bt:LongStrings>
    </Resources>
  </VersionOverrides>
</OfficeApp>
